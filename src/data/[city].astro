---
// [city].astro
// This component generates static pages for each city in cities.json

// Import the cities data
import cities from '../data/cities.json';

// Generate static paths for all cities
export async function getStaticPaths() {
  return cities.map((city) => ({
    params: { city: city.slug },
    props: { city },
  }));
}

// Define the props type (optional but helpful)
interface City {
  slug: string;
  cityName: string;
  stateCode: string;
  stateName: string;
  zipCode: string;
}

const { city } = Astro.props as { city: City };
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>24/7 Emergency Plumbing | {city.cityName}, {city.stateCode}</title>
  <!-- Tailwind via CDN + a touch of custom urgency -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Font Awesome for icons -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css" />
  <style>
    /* micro-interactions & trust badges */
    .hover-lift { transition: transform 0.15s ease; }
    .hover-lift:hover { transform: translateY(-3px); }
    .bg-urgency { background: #0b2b5c; } /* deep navy */
    .border-urgent { border-color: #f59e0b; }
    .call-glow { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.6); animation: pulse-call 2s infinite; }
    @keyframes pulse-call { 0% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0.5); } 70% { box-shadow: 0 0 0 12px rgba(245, 158, 11, 0); } 100% { box-shadow: 0 0 0 0 rgba(245, 158, 11, 0); } }
    .bg-soft-blue { background: #eef2f9; }
    .text-urgent-orange { color: #f59e0b; }
    .border-soft { border-color: #dce3f0; }
    .shadow-card { box-shadow: 0 12px 30px -8px rgba(0,20,40,0.12); }
  </style>
</head>
<body class="font-sans antialiased bg-white text-gray-800">

  <!-- ========== STICKY HEADER with MASSIVE CLICK-TO-CALL ========== -->
  <header class="sticky top-0 z-50 bg-white/95 backdrop-blur-sm shadow-md border-b border-gray-200/80">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-between py-2 md:py-3">
        <!-- Logo / Brand -->
        <div class="flex items-center space-x-2">
          <span class="text-2xl md:text-3xl font-extrabold tracking-tight text-urgent-orange"><i class="fas fa-wrench mr-1 text-blue-700"></i>Plumb<span class="text-blue-700">Pro</span></span>
          <span class="hidden sm:inline-block bg-blue-700 text-white text-[10px] font-bold uppercase px-2 py-0.5 rounded-full tracking-wider">24/7</span>
        </div>

        <!-- Desktop CTA (massive) + small tagline -->
        <div class="flex items-center gap-3">
          <div class="hidden lg:flex items-center text-sm text-gray-600 border-r border-gray-300 pr-3">
            <i class="fas fa-map-pin text-urgent-orange mr-1"></i>
            <span>{city.cityName}, {city.stateCode}</span>
          </div>
          <a href="tel:+18315326042" 
             class="call-glow inline-flex items-center gap-2 bg-urgent-orange hover:bg-orange-500 text-white font-bold text-base sm:text-lg md:text-xl lg:text-2xl px-4 sm:px-6 py-2.5 md:py-3 rounded-full transition-all duration-200 shadow-lg hover:shadow-xl">
            <i class="fas fa-phone-alt"></i> <span class="tracking-wide">+1 (831) 532-6042</span>
            <span class="hidden xs:inline-block bg-white/20 text-[10px] uppercase font-extrabold px-2 py-0.5 rounded-full ml-1">call now</span>
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- ========== HERO : URGENT HEADLINE ========== -->
  <section class="relative bg-gradient-to-br from-blue-900 via-blue-800 to-blue-700 text-white overflow-hidden">
    <div class="absolute inset-0 opacity-10 bg-[url('data:image/svg+xml;base64,PHN2ZyB4bWxucz0iaHR0cDovL3d3dy53My5vcmcvMjAwMC9zdmciIHdpZHRoPSI2MCIgaGVpZ2h0PSI2MCIgdmlld0JveD0iMCAwIDYwIDYwIj48cGF0aCBkPSJNMzAgMTBhMjAgMjAgMCAwIDEgMjAgMjAgMjAgMjAgMCAwIDEtNDAgMCAyMCAyMCAwIDAgMSAyMC0yMHoiIGZpbGw9IiNmZmZmZmYiIG9wYWNpdHk9IjAuMDYiLz48L3N2Zz4=')]"></div>
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 md:py-24 lg:py-32">
      <div class="max-w-3xl">
        <div class="inline-block bg-urgent-orange/20 backdrop-blur-sm text-urgent-orange font-bold text-sm px-4 py-1.5 rounded-full mb-4 border border-urgent-orange/30">
          <i class="fas fa-clock mr-2"></i> 24/7 Emergency Response
        </div>
        <h1 class="text-4xl sm:text-5xl md:text-6xl font-extrabold leading-tight tracking-tight">
          24/7 Emergency Plumbing Services <br class="hidden sm:block" />
          in <span class="text-urgent-orange underline decoration-4 decoration-blue-400/50 underline-offset-4">{city.cityName}</span>, <span class="text-blue-200">{city.stateCode}</span>
        </h1>
        <p class="mt-5 text-lg sm:text-xl text-blue-100/90 max-w-2xl">
          <i class="fas fa-check-circle text-urgent-orange mr-2"></i> Licensed, insured & available now — we fix leaks, drains, heaters, and more.
        </p>
        <div class="mt-8 flex flex-wrap gap-4">
          <a href="tel:+18315326042" class="inline-flex items-center gap-3 bg-urgent-orange hover:bg-orange-500 text-white font-bold text-lg sm:text-xl px-8 py-4 rounded-xl shadow-2xl hover:shadow-orange-500/30 transition-all duration-200">
            <i class="fas fa-phone-alt text-2xl"></i> Call Now: (831) 532-6042
          </a>
          <span class="inline-flex items-center text-white/80 text-sm bg-white/10 backdrop-blur-sm px-5 py-3 rounded-full border border-white/10">
            <i class="fas fa-shield-alt text-urgent-orange mr-2"></i> 100% satisfaction
          </span>
        </div>
        <!-- trust micro -->
        <div class="mt-8 flex flex-wrap items-center gap-6 text-sm text-blue-200/80">
          <span><i class="fas fa-star text-urgent-orange mr-1"></i> 4.9 ★ (1,200+ reviews)</span>
          <span><i class="fas fa-user-md mr-1"></i> Licensed & insured</span>
          <span><i class="fas fa-clock mr-1"></i> Arrive in 45 min</span>
        </div>
      </div>
    </div>
    <!-- subtle wave -->
    <div class="absolute bottom-0 left-0 right-0">
      <svg viewBox="0 0 1440 60" fill="none" xmlns="http://www.w3.org/2000/svg"><path d="M0 40L60 35L120 30L180 35L240 40L300 30L360 25L420 30L480 40L540 35L600 25L660 20L720 25L780 35L840 30L900 20L960 25L1020 35L1080 30L1140 20L1200 25L1260 35L1320 30L1380 20L1440 25V60H0V40Z" fill="white" fill-opacity="0.08"/></svg>
    </div>
  </section>

  <!-- ========== SERVICES WE OFFER ========== -->
  <section class="py-16 md:py-20 bg-soft-blue">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12">
        <span class="text-urgent-orange font-bold text-sm tracking-widest uppercase"><i class="fas fa-wrench mr-2"></i> expertise</span>
        <h2 class="text-3xl md:text-4xl font-extrabold text-gray-800 mt-1">Services We Offer <span class="text-blue-700">in {city.cityName}</span></h2>
        <div class="w-24 h-1 bg-urgent-orange mx-auto mt-3 rounded-full"></div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
        <!-- card 1 -->
        <div class="bg-white rounded-2xl shadow-card hover-lift p-6 border border-gray-200/60 transition-all hover:border-urgent-orange/30 group">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-3xl text-urgent-orange group-hover:scale-110 transition-transform">💧</div>
          <h3 class="text-xl font-bold mt-4 text-gray-800">Leaky Pipes</h3>
          <p class="text-gray-600 text-sm mt-1">Fast detection & repair — stop water damage now.</p>
          <div class="mt-4 text-blue-600 text-sm font-semibold"><i class="fas fa-arrow-right"></i> same-day service</div>
        </div>
        <!-- card 2 -->
        <div class="bg-white rounded-2xl shadow-card hover-lift p-6 border border-gray-200/60 transition-all hover:border-urgent-orange/30 group">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-3xl text-urgent-orange group-hover:scale-110 transition-transform">🚰</div>
          <h3 class="text-xl font-bold mt-4 text-gray-800">Clogged Drains</h3>
          <p class="text-gray-600 text-sm mt-1">Hydro-jetting & snaking — clear drains fast.</p>
          <div class="mt-4 text-blue-600 text-sm font-semibold"><i class="fas fa-arrow-right"></i> 45 min arrival</div>
        </div>
        <!-- card 3 -->
        <div class="bg-white rounded-2xl shadow-card hover-lift p-6 border border-gray-200/60 transition-all hover:border-urgent-orange/30 group">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-3xl text-urgent-orange group-hover:scale-110 transition-transform">🔥</div>
          <h3 class="text-xl font-bold mt-4 text-gray-800">Water Heater Repair</h3>
          <p class="text-gray-600 text-sm mt-1">Gas & electric — restore hot water today.</p>
          <div class="mt-4 text-blue-600 text-sm font-semibold"><i class="fas fa-arrow-right"></i> licensed techs</div>
        </div>
        <!-- card 4 -->
        <div class="bg-white rounded-2xl shadow-card hover-lift p-6 border border-gray-200/60 transition-all hover:border-urgent-orange/30 group">
          <div class="w-14 h-14 bg-blue-50 rounded-xl flex items-center justify-center text-3xl text-urgent-orange group-hover:scale-110 transition-transform">🚽</div>
          <h3 class="text-xl font-bold mt-4 text-gray-800">Toilet Installation</h3>
          <p class="text-gray-600 text-sm mt-1">Efficient installs & repairs — low-flow, smart, standard.</p>
          <div class="mt-4 text-blue-600 text-sm font-semibold"><i class="fas fa-arrow-right"></i> upfront pricing</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FEATURE MATRIX / CONVERSION (trust + urgency) ========== -->
  <section class="py-16 md:py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-6 items-start">
        <!-- left: huge call to action -->
        <div class="lg:col-span-2 bg-gradient-to-br from-blue-700 to-blue-800 rounded-2xl p-8 text-white shadow-xl">
          <div class="flex items-start gap-3">
            <span class="text-4xl"><i class="fas fa-phone-alt text-urgent-orange"></i></span>
            <div>
              <h3 class="text-2xl font-bold">Need a plumber <br class="sm:hidden" />right now?</h3>
              <p class="text-blue-100 text-sm mt-1">Call us — we pick up 24/7/365</p>
            </div>
          </div>
          <div class="mt-6">
            <a href="tel:+18315326042" class="block text-center bg-urgent-orange hover:bg-orange-500 text-white font-extrabold text-2xl py-4 px-4 rounded-xl shadow-lg transition-all">
              <i class="fas fa-phone-alt mr-2"></i> (831) 532-6042
            </a>
            <p class="text-xs text-blue-200 mt-3 text-center"><i class="fas fa-check-circle text-urgent-orange mr-1"></i> No hidden fees • free estimate</p>
          </div>
          <div class="mt-6 grid grid-cols-2 gap-2 text-sm">
            <div class="bg-white/10 backdrop-blur-sm rounded-lg p-3 text-center"><i class="fas fa-map-pin text-urgent-orange"></i> {city.cityName}, {city.stateCode}</div>
            <div class="bg-white/10 backdrop-blur-sm rounded-lg p-3 text-center"><i class="fas fa-clock"></i> 24/7 emergency</div>
          </div>
        </div>

        <!-- right: professional feature matrix -->
        <div class="lg:col-span-3 grid sm:grid-cols-2 gap-4">
          <div class="bg-soft-blue p-5 rounded-xl border border-white shadow-sm">
            <i class="fas fa-certificate text-urgent-orange text-2xl"></i>
            <h4 class="font-bold text-gray-800 mt-2">Licensed & Insured</h4>
            <p class="text-sm text-gray-600">Fully compliant with Texas, California & Florida state boards.</p>
          </div>
          <div class="bg-soft-blue p-5 rounded-xl border border-white shadow-sm">
            <i class="fas fa-dollar-sign text-urgent-orange text-2xl"></i>
            <h4 class="font-bold text-gray-800 mt-2">Upfront Flat Pricing</h4>
            <p class="text-sm text-gray-600">No overtime fees, no surprises — we quote before we work.</p>
          </div>
          <div class="bg-soft-blue p-5 rounded-xl border border-white shadow-sm">
            <i class="fas fa-tools text-urgent-orange text-2xl"></i>
            <h4 class="font-bold text-gray-800 mt-2">Modern Equipment</h4>
            <p class="text-sm text-gray-600">Camera inspection, hydro-jetting, leak detection.</p>
          </div>
          <div class="bg-soft-blue p-5 rounded-xl border border-white shadow-sm">
            <i class="fas fa-star text-urgent-orange text-2xl"></i>
            <h4 class="font-bold text-gray-800 mt-2">4.9 ★ Rated</h4>
            <p class="text-sm text-gray-600">Over 1,200 verified reviews — we’re the trusted local team.</p>
          </div>
          <div class="sm:col-span-2 bg-blue-50 p-4 rounded-xl border border-blue-100 flex flex-wrap items-center justify-between">
            <span class="font-semibold text-gray-700"><i class="fas fa-shield-alt text-urgent-orange mr-2"></i> 100% satisfaction guarantee</span>
            <span class="text-sm bg-white px-4 py-1.5 rounded-full shadow-sm text-blue-700 font-medium"><i class="fas fa-phone mr-1"></i> call for immediate dispatch</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========== FINAL TRUST BAR + LOCATION ========== -->
  <section class="py-10 bg-gray-50 border-t border-gray-200/60">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-wrap items-center justify-between gap-4 text-sm text-gray-600">
        <div class="flex items-center gap-4 flex-wrap">
          <span class="bg-blue-100 text-blue-700 px-4 py-2 rounded-full font-semibold"><i class="fas fa-map-marker-alt text-urgent-orange mr-2"></i> Serving {city.cityName}, {city.stateName} ({city.stateCode})</span>
          <span><i class="fas fa-check-circle text-green-500 mr-1"></i> Available in TX, CA, FL</span>
        </div>
        <div class="flex items-center gap-3">
          <span class="bg-white px-4 py-2 rounded-full shadow-sm border border-gray-200"><i class="fas fa-credit-card"></i> All major cards</span>
          <span class="bg-white px-4 py-2 rounded-full shadow-sm border border-gray-200"><i class="fas fa-clock"></i> 24/7</span>
        </div>
      </div>
      <!-- final micro cta -->
      <div class="mt-6 text-center">
        <a href="tel:+18315326042" class="inline-block bg-blue-700 hover:bg-blue-800 text-white font-bold px-8 py-3 rounded-full shadow-md transition-all text-lg">
          <i class="fas fa-phone-alt mr-2"></i> Call {city.cityName} Plumber Now: (831) 532-6042
        </a>
      </div>
      <p class="text-center text-[10px] uppercase tracking-widest text-gray-400 mt-6 border-t border-gray-200/70 pt-4">
        <i class="fas fa-shield-alt"></i> emergency plumbing • {city.cityName} • {city.stateCode} • pay-per-call
      </p>
    </div>
  </section>

  <!-- optional note: dynamic placeholders shown in UI -->
  <div class="text-[10px] text-center text-gray-300 py-2 bg-white border-t border-gray-100">
    <span class="bg-gray-50 px-2 py-0.5 rounded">📍 {city.cityName}, {city.stateName} ({city.stateCode})</span> — <span class="text-urgent-orange">★</span> premium contractor
  </div>

</body>
</html>
